{
  "convertToken": false,
  "tokenEndpoint": "https://your-gateway.com/token",
  "rateLimitEnabled": false,
  "debugPath": "./logs",
  "providers": {
    "openai": {
      "routePrefix": "/openai",
      "upstreamTemplate-example": "https://your-gateway.com/genai/oai/{model}",
      "upstreamTemplate": "https://api.openai.com",
      "defaultModel": "gpt-5.1-2025-11-13",
      "disableStreaming": true,
      "mimicStreaming": false,
      "tokenLimitPerMinute": 200000,
      "stripRequestProperties": ["max_tokens"],
      "models": {
        "gpt-5.1-2025-11-13": {
          "modelAlias": "gpt-5.1"
        }
      }
    },
    "anthropic": {
      "routePrefix": "/anthropic",
      "upstreamTemplate": "https://api.bedrock.com/{model}/v1",
      "upstreamTemplate-bedrock-example": "https://api.bedrock.com/{model}/v1",
      "defaultModel": "anthropic-claude-sonnet-4-6",
      "disableStreaming": false,
      "mimicStreaming": true,
      "tokenLimitPerMinute": 200000,
      "stripRequestProperties": [],
      "models": {
        "anthropic-claude-sonnet-4-6": {
          "modelAlias": "sonnet-4.6"
        },
        "anthropic-claude-opus-4-6": {
          "modelAlias": "opus-4.6"
        }
      }
    }
  }
}
