{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  //// Note: You can set the default model for OpenCode by toggling the
  ////  desired line below. Make sure to choose a model that is enabled in
  //// the "enabled_providers" section below.
  "model": "kepler-bun-proxy-openai/gpt-5.1",
  ////
  "enabled_providers": [
    "kepler-bun-proxy-openai",
    "kepler-bun-proxy-anthropic"
  ],
  "provider": {
    "kepler-bun-proxy-openai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "kepler-bun-proxy (OpenAI Completions)",
      "options": {
        "baseURL": "http://localhost:4000/openai/v1/",
        "apiKey": "ignore"
      },
      "models": {
        "gpt-5.1": {
          "name": "GPT-5.1",
          "tool_call": true,
          "reasoning": true
        }
      }
    },
    "kepler-bun-proxy-anthropic": {
      "npm": "@ai-sdk/anthropic",
      "name": "kepler-bun-proxy (Anthropic Messages)",
      "options": {
        "baseURL": "http://localhost:4000/anthropic/v1/",
        "apiKey": "ignore"
      },
      "models": {
        "anthropic-claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6",
          "tool_call": true,
          "reasoning": true
        },
        "anthropic-claude-opus-4-6": {
          "name": "Claude Opus 4.6",
          "tool_call": true,
          "reasoning": true
        }
      }
    }
  }
}
